Project collaboration_hub {
  database_type: 'PostgreSQL'
  Note: '''
    Demonstrates DBML language features used by this repo:
    TableGroup, TablePartial, sticky notes, colored refs/groups/headers,
    relationship cardinalities, defaults and indexes.
  '''
}

TablePartial base_audit [headerColor: #0EA5E9] {
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    created_at [name: 'idx_created_at']
  }
}

TablePartial soft_delete {
  is_deleted boolean [not null, default: false]
  deleted_at timestamp [default: null]
}

TablePartial tenant_scope {
  tenant_id uuid [not null]

  indexes {
    tenant_id [name: 'idx_tenant_scope']
  }
}

Table accounts [headercolor: #1D4ED8] {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email varchar(255) [not null, unique]
  status varchar(20) [not null, default: 'active']
  signup_source varchar(30) [default: 'organic']
  credits int [not null, default: 0]
  marketing_opt_in boolean [not null, default: false]
  trial_ends_at timestamp [default: null]

  ~tenant_scope
  ~base_audit

  indexes {
    (tenant_id, email) [unique, name: 'uq_accounts_tenant_email']
    status [name: 'idx_accounts_status']
  }

  Note: 'Identity account for each user under a tenant.'
}

Table profiles [headercolor: #14B8A6] {
  account_id uuid [pk, not null]
  display_name varchar(120) [not null, default: 'New User']
  avatar_url varchar(2048)
  timezone varchar(50) [not null, default: 'UTC']

  ~base_audit
  ~soft_delete

  Note: 'One profile row per account (1:1 relation).'
}

Table workspaces [headercolor: #2563EB] {
  id uuid [pk, default: `gen_random_uuid()`]
  owner_account_id uuid [not null]
  name varchar(120) [not null]
  visibility varchar(20) [not null, default: 'private']

  ~tenant_scope
  ~base_audit

  indexes {
    (tenant_id, name) [unique, name: 'uq_workspace_name_per_tenant']
  }
}

Table workspace_members [headercolor: #0F766E] {
  workspace_id uuid [not null]
  account_id uuid [not null]
  role varchar(30) [not null, default: 'editor']
  invited_by_account_id uuid
  joined_at timestamp [not null, default: `now()`]

  indexes {
    (workspace_id, account_id) [pk]
    account_id [name: 'idx_workspace_members_account']
  }
}

Table posts [headercolor: #F59E0B] {
  id bigint [pk, increment]
  author_id uuid [not null]
  workspace_id uuid [not null]
  title varchar(255) [not null]
  body text [not null]
  status varchar(20) [not null, default: 'draft']
  upvotes int [not null, default: 0]

  ~base_audit

  indexes {
    (workspace_id, status) [name: 'idx_posts_workspace_status']
  }
}

Table comments [headercolor: #FB7185] {
  id bigint [pk, increment]
  post_id bigint [not null]
  author_id uuid [not null]
  body text [not null]
  is_internal boolean [not null, default: false]

  ~base_audit
}

Table tags [headercolor: #A855F7] {
  id int [pk, increment]
  name varchar(80) [not null, unique]
  label_color varchar(20) [not null, default: '#A855F7']

  ~base_audit
}

TableGroup IdentityAndAccess [color: #3B82F6, note: 'Tenant identity and access management tables.'] {
  accounts
  profiles
  workspaces
  workspace_members
}

TableGroup ContentModel [color: #F97316, note: 'Publishing entities with comments and taxonomy.'] {
  posts
  comments
  tags
}

Ref: posts.author_id > accounts.id [delete: restrict, update: cascade, color: #FB923C]
Ref: accounts.id < workspaces.owner_account_id [delete: cascade, color: #22C55E]
Ref: accounts.id - profiles.account_id [delete: cascade, color: #EF4444]
Ref: posts.id <> tags.id [color: #A855F7]
Ref: workspace_members.workspace_id > workspaces.id [delete: cascade, color: #06B6D4]
Ref: workspace_members.account_id > accounts.id [delete: cascade, color: #06B6D4]
Ref: comments.post_id > posts.id [delete: cascade, color: #F43F5E]
Ref: comments.author_id > accounts.id [delete: restrict, color: #F43F5E]

Note architecture_note {
  'Sticky note: <> is shown for conceptual many-to-many between posts and tags.'
}

Note defaults_note {
  '''
    Sticky note: defaults here demonstrate all common types:
    number (credits), string (status), boolean (marketing_opt_in),
    null (trial_ends_at), and expression (`now()`, `gen_random_uuid()`).
  '''
}
