Project warehouse_ops {
  database_type: 'PostgreSQL'
  Note: 'Second showcase document focused on operations and logistics.'
}

TablePartial timestamps [headerColor: #22C55E] {
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

TablePartial status_flags {
  is_active boolean [not null, default: true]
  archived_at timestamp [default: null]
}

Table users [headercolor: #16A34A] {
  id int [pk, increment]
  email varchar(255) [not null, unique]
  display_name varchar(120) [not null]
  locale varchar(10) [not null, default: 'en-GB']

  ~timestamps
}

Table vendors [headercolor: #0EA5E9] {
  id int [pk, increment]
  code varchar(30) [not null, unique]
  name varchar(150) [not null]
  rating int [not null, default: 3]

  ~timestamps
  ~status_flags

  indexes {
    name [name: 'idx_vendors_name']
  }
}

Table products [headercolor: #38BDF8] {
  id int [pk, increment]
  sku varchar(64) [not null, unique]
  name varchar(160) [not null]
  unit_cost decimal(12,2) [not null, default: 0]
  reorder_threshold int [not null, default: 10]

  ~timestamps

  indexes {
    (name, sku) [name: 'idx_products_name_sku']
  }
}

Table warehouses [headercolor: #84CC16] {
  id int [pk, increment]
  code varchar(24) [not null, unique]
  city varchar(80) [not null]
  capacity_units int [not null, default: 0]

  ~timestamps
}

Table inventory [headercolor: #65A30D] {
  warehouse_id int [not null]
  product_id int [not null]
  quantity_on_hand int [not null, default: 0]
  quantity_reserved int [not null, default: 0]

  ~timestamps

  indexes {
    (warehouse_id, product_id) [pk]
    product_id [name: 'idx_inventory_product']
  }
}

Table purchase_orders [headercolor: #F59E0B] {
  id bigint [pk, increment]
  vendor_id int [not null]
  approved_by_user_id int
  po_number varchar(40) [not null, unique]
  status varchar(20) [not null, default: 'draft']
  approved_at timestamp [default: null]

  ~timestamps

  indexes {
    status [name: 'idx_po_status']
  }
}

Table shipment_receipts [headercolor: #F97316] {
  id bigint [pk, increment]
  purchase_order_id bigint [not null]
  warehouse_id int [not null]
  received_by_user_id int [not null]
  received_at timestamp [not null, default: `now()`]

  ~timestamps
}

Table user_badges [headercolor: #A855F7] {
  user_id int [not null]
  badge_name varchar(60) [not null]
  earned_at timestamp [not null, default: `now()`]

  indexes {
    (user_id, badge_name) [pk]
  }
}

TableGroup Operations [color: #22C55E, note: 'Core operational inventory tables.'] {
  products
  warehouses
  inventory
  purchase_orders
  shipment_receipts
}

TableGroup PeopleAndPartners [color: #0EA5E9, note: 'Users and vendors participating in workflows.'] {
  users
  vendors
  user_badges
}

Ref: purchase_orders.vendor_id > vendors.id [delete: restrict, color: #0EA5E9]
Ref: users.id < purchase_orders.approved_by_user_id [delete: set null, color: #16A34A]
Ref: users.id - user_badges.user_id [delete: cascade, color: #A855F7]
Ref: products.id <> vendors.id [color: #38BDF8]
Ref: inventory.product_id > products.id [delete: cascade, color: #65A30D]
Ref: inventory.warehouse_id > warehouses.id [delete: cascade, color: #65A30D]
Ref: shipment_receipts.purchase_order_id > purchase_orders.id [delete: cascade, color: #F97316]
Ref: shipment_receipts.warehouse_id > warehouses.id [delete: restrict, color: #84CC16]
Ref: shipment_receipts.received_by_user_id > users.id [delete: restrict, color: #16A34A]

Note relation_legend {
  '''
    Sticky note legend:
    > many-to-one, < one-to-many, - one-to-one, <> many-to-many.
  '''
}
