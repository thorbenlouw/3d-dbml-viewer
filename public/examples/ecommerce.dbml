Table customers {
  id int [pk, increment]
  email varchar(255) [not null, unique]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  phone varchar(20)
  created_at timestamp [not null]

  note: 'Registered customers who can place orders and write reviews.'
}

Table addresses {
  id int [pk, increment]
  customer_id int [not null]
  line1 varchar(255) [not null]
  line2 varchar(255)
  city varchar(100) [not null]
  state varchar(100)
  postal_code varchar(20) [not null]
  country_code char(2) [not null]
  is_default boolean [not null, default: false]

  note: 'Shipping and billing addresses belonging to a customer.'
}

Table categories {
  id int [pk, increment]
  parent_id int
  name varchar(100) [not null]
  slug varchar(100) [not null, unique]

  note: 'Hierarchical product categories. parent_id is null for top-level categories.'
}

Table products {
  id int [pk, increment]
  sku varchar(100) [not null, unique]
  name varchar(255) [not null]
  description text
  price decimal(10,2) [not null]
  stock_quantity int [not null, default: 0]
  created_at timestamp [not null]

  note: 'Catalogue of items available for purchase.'
}

Table product_categories {
  product_id int [not null]
  category_id int [not null]

  indexes {
    (product_id, category_id) [pk]
  }

  note: 'Many-to-many join between products and categories.'
}

Table coupons {
  id int [pk, increment]
  code varchar(50) [not null, unique]
  discount_percent decimal(5,2)
  discount_fixed decimal(10,2)
  valid_from timestamp [not null]
  valid_until timestamp
  max_uses int

  note: 'Discount codes that can be applied to an order at checkout.'
}

Table orders {
  id int [pk, increment]
  customer_id int [not null]
  shipping_address_id int [not null]
  coupon_id int
  status varchar(30) [not null, default: 'pending']
  total_amount decimal(10,2) [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  note: 'A purchase transaction. Status flows: pending → confirmed → shipped → delivered.'
}

Table order_items {
  id int [pk, increment]
  order_id int [not null]
  product_id int [not null]
  quantity int [not null]
  unit_price decimal(10,2) [not null]

  note: 'Individual line items within an order.'
}

Table payments {
  id int [pk, increment]
  order_id int [not null]
  provider varchar(50) [not null]
  provider_reference varchar(255) [not null, unique]
  amount decimal(10,2) [not null]
  status varchar(30) [not null]
  paid_at timestamp

  note: 'Payment transactions linked to an order. An order may have multiple attempts.'
}

Table reviews {
  id int [pk, increment]
  product_id int [not null]
  customer_id int [not null]
  rating smallint [not null]
  title varchar(255)
  body text
  created_at timestamp [not null]

  note: 'Customer reviews and star ratings for products.'
}

Ref: addresses.customer_id > customers.id
Ref: categories.parent_id > categories.id
Ref: product_categories.product_id > products.id
Ref: product_categories.category_id > categories.id
Ref: orders.customer_id > customers.id
Ref: orders.shipping_address_id > addresses.id
Ref: orders.coupon_id > coupons.id
Ref: order_items.order_id > orders.id
Ref: order_items.product_id > products.id
Ref: payments.order_id > orders.id
Ref: reviews.product_id > products.id
Ref: reviews.customer_id > customers.id
