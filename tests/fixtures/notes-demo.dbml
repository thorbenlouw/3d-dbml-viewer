Table follows [note: 'Adjacency list capturing social follow relationships between users'] {
  following_user_id integer
  followed_user_id integer
  created_at timestamp
}

Table users {
  id integer [primary key]
  username varchar
  role varchar [note: 'One of: admin, editor, viewer']
  created_at timestamp
}

Table posts {
  id integer [primary key]
  title varchar
  body text [note: 'Markdown content stored as plain text; HTML is escaped on read']
  user_id integer [not null]
  status varchar [note: 'draft | published | archived']
  created_at timestamp
}

Ref user_posts: posts.user_id > users.id

Ref: users.id < follows.following_user_id

Ref: users.id < follows.followed_user_id
